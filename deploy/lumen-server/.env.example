# Copy this file to `.env` on the VPS before using docker compose.
# The defaults mirror the currently running container inspected on 2026-05-06.

LUMEN_BUN_IMAGE=oven/bun:1

# Keep the server bound to localhost. OpenResty/Nginx should proxy public HTTP(S)
# traffic to this port instead of exposing Bun directly to the internet.
LUMEN_BIND_HOST=127.0.0.1
LUMEN_HOST_PORT=3000

# Current host-side bind mounts.
LUMEN_APP_DIR=/opt/lumen/current
LUMEN_DATA_DIR=/opt/lumen/data
LUMEN_KEYS_DIR=/opt/lumen/keys

# Optional beta controls.
# LUMEN_INVITES_REQUIRED=1
# LUMEN_OPERATOR_HANDLES=your-handle
# LUMEN_OPERATOR_USER_IDS=01...
