{
  "manifest_version": 3,
  "name": "Lumen v2",
  "version": "0.1.0",
  "description": "Contextual social commenting on real webpages.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lumen"
  },
  "background": {
    "service_worker": "src/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["src/content.tsx"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
